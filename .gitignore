# Project data
postgres_data/

# Node — catch ALL levels (root + frontend + sandcastle worktrees).
# Sandcastle copies node_modules into per-issue worktrees; if you only
# ignore frontend/node_modules/, a sandcastle merge can leak full
# node_modules contents (Claude Agent SDK binaries are 230MB each) into
# git history. Catch every level.
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dev-dist/
frontend/.vite/

# Sandcastle: track the orchestrator (prompts, Dockerfile, main.mts)
# but NOT runtime artifacts (env, logs, per-issue worktrees).
.sandcastle/.env-sandcastle
.sandcastle/.env
.sandcastle/logs/
.sandcastle/worktrees/
.env-sandcastle

# Project-local Claude skills (already in tree once; don't auto-track future ones)
# .claude/
